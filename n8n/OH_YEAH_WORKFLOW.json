        "jsCode": "// Agrupa la lista de 20 o 25 productos en un único objeto contenedor\nconst products = $input.all().map(item => ({\n    external_id: item.json.external_id,\n    title: item.json.title,\n    description: item.json.description\n}));\n\nreturn { json: { lista: products } };\n"
